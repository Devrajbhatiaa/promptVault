<%- include('head') %>
<%- include('nav') %>
<style>
.post-detail { padding: 40px 0 80px; position: relative; z-index: 1; }
.post-header { background: var(--s1); border: 1px solid var(--border); border-radius: var(--rl); padding: 28px; margin-bottom: 24px; }
.post-title { font-size: 26px; font-weight: 800; margin-bottom: 16px; line-height: 1.3; }
.post-meta { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; flex-wrap: wrap; }
.post-author { display: flex; align-items: center; gap: 10px; }
.author-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent-h)); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: white; }
.author-info { font-size: 14px; }
.author-name { font-weight: 600; }
.post-date { color: var(--t3); font-size: 13px; }
.category-tag { display: inline-flex; padding: 4px 12px; background: var(--s2); border-radius: 12px; font-size: 12px; color: var(--t2); text-transform: capitalize; }
.post-content { font-size: 15px; line-height: 1.9; color: var(--text); white-space: pre-wrap; margin-bottom: 24px; }
.post-actions { display: flex; gap: 12px; padding-top: 16px; border-top: 1px solid var(--border); }
.action-btn { display: flex; align-items: center; gap: 6px; padding: 8px 16px; background: var(--s2); border: 1px solid var(--border); border-radius: var(--r); color: var(--t2); font-size: 14px; cursor: pointer; transition: all var(--tr); }
.action-btn:hover { border-color: var(--border-h); color: var(--text); }
.action-btn.liked { color: var(--red); border-color: var(--red); background: rgba(226,75,74,0.1); }
.delete-btn { color: var(--red); border-color: rgba(226,75,74,0.3); }
.delete-btn:hover { background: var(--red-bg); }

/* Comments */
.comments-section { background: var(--s1); border: 1px solid var(--border); border-radius: var(--rl); padding: 24px; }
.comments-header { font-size: 18px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
.comment-form { margin-bottom: 24px; }
.comment-form textarea { width: 100%; background: var(--s2); border: 1px solid var(--border); border-radius: var(--r); padding: 14px; color: var(--text); font-size: 14px; font-family: inherit; resize: vertical; min-height: 80px; }
.comment-form textarea:focus { outline: none; border-color: var(--accent); }
.comment-form-actions { display: flex; justify-content: flex-end; margin-top: 10px; }
.comments-list { display: flex; flex-direction: column; gap: 16px; }
.comment-item { background: var(--s2); border-radius: var(--r); padding: 16px; }
.comment-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.comment-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: white; }
.comment-author { font-weight: 600; font-size: 14px; }
.comment-date { color: var(--t3); font-size: 12px; }
.comment-content { font-size: 14px; line-height: 1.6; color: var(--text); }
.comment-actions { display: flex; gap: 12px; margin-top: 10px; }
.comment-action-btn { background: none; border: none; color: var(--t3); font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 4px; }
.comment-action-btn:hover { color: var(--text); }
.comment-replies { margin-top: 16px; margin-left: 20px; padding-left: 16px; border-left: 2px solid var(--border); }
.reply-item { background: var(--s1); border-radius: var(--r); padding: 12px; margin-top: 10px; }
.back-link { display: inline-flex; align-items: center; gap: 6px; color: var(--t2); font-size: 14px; margin-bottom: 20px; }
.back-link:hover { color: var(--accent); }
</style>

<div class="page-wrap">
  <div class="post-detail container" style="max-width:800px;">
    <a href="<%= post.community ? '/community/' + post.community._id : '/trending' %>" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Back to <%= post.community ? 'Community' : 'Trending' %>
    </a>

    <div class="post-header slide-up">
      <h1 class="post-title"><%= post.title %></h1>
      <div class="post-meta">
        <div class="post-author">
          <div class="author-avatar"><%= post.author?.name?.charAt(0).toUpperCase() || 'U' %></div>
          <div class="author-info">
            <div class="author-name"><%= post.author?.name || 'Unknown' %></div>
            <div class="post-date"><%= new Date(post.createdAt).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></div>
          </div>
        </div>
        <% if (post.category) { %>
          <span class="category-tag"><%= post.category %></span>
        <% } %>
      </div>
      <div class="post-content"><%= post.content %></div>
      <div class="post-actions">
        <form action="/post/<%= post._id %>/like" method="POST" style="display:inline;">
          <button type="submit" class="action-btn <%= isLiked ? 'liked' : '' %>">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="<%= isLiked ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            <%= post.likes?.length || 0 %> Likes
          </button>
        </form>
        <div class="action-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          <%= post.views || 0 %> Views
        </div>
        <% if (user && post.author && user._id.toString() === post.author._id.toString()) { %>
          <form action="/post/<%= post._id %>/delete" method="POST" style="display:inline;">
            <button type="submit" class="action-btn delete-btn" onclick="return confirm('Delete this prompt?')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
              Delete
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <div class="comments-section slide-up">
      <div class="comments-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Comments (<%= comments.length %>)
      </div>

      <% if (user) { %>
        <form class="comment-form" action="/post/<%= post._id %>/comment" method="POST">
          <textarea name="content" placeholder="Write a comment..." required></textarea>
          <div class="comment-form-actions">
            <button type="submit" class="btn btn-primary btn-sm">Post Comment</button>
          </div>
        </form>
      <% } else { %>
        <p style="color:var(--t2);font-size:14px;margin-bottom:20px;"> <a href="/login" style="color:var(--accent);">Login</a> to post a comment.</p>
      <% } %>

      <div class="comments-list">
        <% if (comments.length === 0) { %>
          <p style="text-align:center;color:var(--t3);padding:20px;">No comments yet. Be the first to comment!</p>
        <% } %>
        
        <% comments.forEach(function(comment) { %>
          <div class="comment-item">
            <div class="comment-header">
              <div class="comment-avatar"><%= comment.author?.name?.charAt(0).toUpperCase() || 'U' %></div>
              <div class="comment-author"><%= comment.author?.name || 'Unknown' %></div>
              <div class="comment-date"><%= new Date(comment.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %></div>
            </div>
            <div class="comment-content"><%= comment.content %></div>
            <div class="comment-actions">
              <button class="comment-action-btn">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                <%= comment.likes?.length || 0 %>
              </button>
              <% if (user) { %>
                <button class="comment-action-btn" onclick="showReplyForm('<%= comment._id %>')">Reply</button>
              <% } %>
            </div>
            
            <% if (comment.replies && comment.replies.length > 0) { %>
              <div class="comment-replies">
                <% comment.replies.forEach(function(reply) { %>
                  <div class="reply-item">
                    <div class="comment-header">
                      <div class="comment-avatar" style="width:28px;height:28px;font-size:11px;"><%= reply.author?.name?.charAt(0).toUpperCase() || 'U' %></div>
                      <div class="comment-author"><%= reply.author?.name || 'Unknown' %></div>
                      <div class="comment-date"><%= new Date(reply.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %></div>
                    </div>
                    <div class="comment-content"><%= reply.content %></div>
                  </div>
                <% }); %>
              </div>
            <% } %>
            
            <% if (user) { %>
              <div id="reply-form-<%= comment._id %>" style="display:none;margin-top:12px;">
                <form action="/post/<%= post._id %>/comment" method="POST" style="display:flex;gap:8px;">
                  <input type="hidden" name="parentId" value="<%= comment._id %>"/>
                  <input type="text" name="content" placeholder="Write a reply..." class="form-input" style="flex:1;" required/>
                  <button type="submit" class="btn btn-primary btn-sm">Reply</button>
                </form>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  </div>
</div>

<script src="/main.js"></script>
<script>
function showReplyForm(commentId) {
  const form = document.getElementById('reply-form-' + commentId);
  form.style.display = form.style.display === 'none' ? 'block' : 'none';
}
</script>
</body></html>