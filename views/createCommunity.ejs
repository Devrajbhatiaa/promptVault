<%- include('head') %>
<%- include('nav') %>
<style>
.create-comm-page { padding: 40px 0 80px; position: relative; z-index: 1; }
.form-card { background: var(--s1); border: 1px solid var(--border); border-radius: var(--rx); padding: 40px; max-width: 600px; margin: 0 auto; }
.form-card h1 { font-size: 28px; font-weight: 800; margin-bottom: 8px; }
.form-card .sub { color: var(--t2); font-size: 14px; margin-bottom: 32px; }
.toggle-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.toggle-label { font-size: 14px; font-weight: 500; }
.toggle-desc { font-size: 12px; color: var(--t3); }
</style>

<div class="page-wrap">
  <div class="create-comm-page container-xs" style="max-width:600px;">
    <div class="form-card slide-up">
      <h1>Create Community</h1>
      <p class="sub">Start a new community for prompt creators.</p>
      
      <form action="/community/create" method="POST" style="display:flex;flex-direction:column;gap:20px;">
        <div class="form-group">
          <label class="form-label">Community Name</label>
          <input type="text" name="name" class="form-input" placeholder="e.g., AI Writing Prompts" required minlength="3" maxlength="50"/>
        </div>
        
        <div class="form-group">
          <label class="form-label">Description (optional)</label>
          <textarea name="description" class="form-textarea" rows="3" placeholder="What is this community about?" maxlength="500"></textarea>
        </div>
        
        <div class="toggle-row">
          <label class="toggle">
            <input type="checkbox" name="isPrivate" style="width:18px;height:18px;accent-color:var(--accent);"/>
          </label>
          <div>
            <div class="toggle-label">Private Community</div>
            <div class="toggle-desc">Only invited members can join</div>
          </div>
        </div>
        
        <div style="display:flex;gap:12px;margin-top:8px;">
          <button type="submit" class="btn btn-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" y1="11" x2="23" y2="11"/></svg>
            Create Community
          </button>
          <a href="/communities" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/main.js"></script>
</body></html>